{
  "name": "comunidade-br",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "vercel-build": "npm exec -w client -- vite build",
    "start": "npm run start -w server"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.14",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "socket.io": "^4.8.1",
    "tsx": "^4.19.3",
    "uuid": "^11.1.0",
    "vite": "^6.2.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.2"
  }
}
