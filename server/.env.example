# URL do frontend (usado nos links de convite por e-mail)
APP_URL=http://localhost:5173

# SMTP para envio de e-mails (ex.: Outlook/Hotmail, Gmail, SendGrid)
# Sem estas variáveis, o link de convite aparece no console do servidor.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=seu-email@hotmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Comunidade Brasil <noreply@comunidadebr.app>

JWT_SECRET=altere-em-producao
